# Upstox API Credentials
# Get these from https://developer.upstox.com
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_REDIRECT_URI=http://localhost:8000/callback
UPSTOX_ACCESS_TOKEN=your_access_token_here

# Trading Settings
PAPER_TRADING=true          # Set to false for real money trades
MAX_CAPITAL=50000           # Max capital to use in INR
RISK_PER_TRADE=2            # Risk % per trade (2 = 2%)
DAILY_LOSS_LIMIT=5          # Stop trading if daily loss exceeds this %
DAILY_PROFIT_TARGET=3       # Stop trading after this % daily profit

# Notification (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
